{
    "name": "modular-monolith/installer",
    "description": "Interactive installer for modular-monolith/symfony-application",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "symfony/console": "^7.2|^8.0",
        "symfony/filesystem": "^7.2|^8.0",
        "symfony/process": "^7.2|^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "squizlabs/php_codesniffer": "^4.0",
        "phpstan/phpstan": "^2.2",
        "phpstan/extension-installer": "^1.4"
    },
    "autoload": {
        "psr-4": {
            "ModularMonolith\\Installer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ModularMonolith\\Installer\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/modulith"
    ],
    "scripts": {
        "test": "vendor/bin/phpunit",
        "cs": "vendor/bin/phpcs",
        "cs-fix": "vendor/bin/phpcbf",
        "stan": "vendor/bin/phpstan analyse",
        "build-phar": "bash scripts/build-phar.sh",
        "publish-release": "bash scripts/publish-release.sh"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    }
}
