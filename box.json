{
    "$schema": "https://box-project.github.io/box/schema.json",
    "alias": "modulith.phar",
    "banner": false,
    "base-path": ".",
    "chmod": "0755",
    "check-requirements": true,
    "compression": "GZ",
    "directories": [
        "src",
        "vendor"
    ],
    "dump-autoload": true,
    "exclude-dev-files": true,
    "files": [
        "composer.json"
    ],
    "main": "bin/modulith",
    "output": "build/modulith.phar",
    "replacements": {
        "git-version": "dev"
    }
}
